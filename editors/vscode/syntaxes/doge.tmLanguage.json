{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Doge",
  "scopeName": "source.doge",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#control" },
    { "include": "#modules" },
    { "include": "#builtins" },
    { "include": "#self" },
    { "include": "#doge-keywords" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.doge"
    },
    "strings": {
      "name": "string.quoted.double.doge",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "match": "\\\\.", "name": "constant.character.escape.doge" },
        {
          "name": "meta.interpolation.doge",
          "begin": "(?<!\\\\)\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.doge" } },
          "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.doge" } },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#constants" },
            { "include": "#control" },
            { "include": "#modules" },
            { "include": "#builtins" },
            { "include": "#self" },
            { "include": "#operators" }
          ]
        }
      ]
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.doge"
    },
    "constants": {
      "match": "\\b(true|false|none)\\b",
      "name": "constant.language.doge"
    },
    "control": {
      "match": "\\b(if|elif|else|for|while|in|return|continue|and|or|not)\\b",
      "name": "keyword.control.doge"
    },
    "modules": {
      "match": "\\b(nerd|strings|hunt|fetch|env|howl|json|dson|nap|pack|chase|roll)\\b(?:\\s*\\.\\s*([A-Za-z_][A-Za-z0-9_]*))?",
      "captures": {
        "1": { "name": "support.class.module.doge" },
        "2": { "name": "support.function.method.doge" }
      }
    },
    "builtins": {
      "match": "(?<!\\.)\\b(len|str|int|float|bytes|dec|range|gib)\\b(?=\\s*\\()",
      "name": "support.function.builtin.doge"
    },
    "self": {
      "match": "\\bself\\b",
      "name": "variable.language.self.doge"
    },
    "doge-keywords": {
      "match": "\\b(such|much|many|so|very|super|pls|bark|bonk|bork|amaze|wow)\\b|\\boh\\s+no\\b",
      "name": "keyword.other.doge"
    },
    "operators": {
      "match": "\\*\\*=?|//=?|<<=?|>>=?|[+\\-*/%&|^<>=!]=?|~|[:,\\[\\]().{}]",
      "name": "keyword.operator.doge"
    }
  }
}
